{
  "name": "koala-cluster",
  "version": "1.0.0",
  "description": "7×7 cluster slot — Stake Engine compatible, NORMAL/SUPER, Koala Spins, Gumleaf Grove, Billabong Bonus",
  "private": true,
  "workspaces": ["math", "rgs", "client"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start": "node rgs/server.js",
    "simulate": "node math/run-simulation.js",
    "rgs": "node rgs/server.js",
    "client": "npm run dev -w client",
    "dev": "concurrently \"npm run rgs\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
